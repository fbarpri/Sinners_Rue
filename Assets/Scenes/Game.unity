  m_Name: 
  m_EditorClassIdentifier: '::'
  noOpen:
  - "It\u2019s really cold. I don\u2019t realy want to open the window right now,
    unless I have a good reason to."
  yesOpen:
  - "Whiskers! You\u2019re back. God, I really should\u2019ve cleaned up the kitchen.
    I can\u2019t believe I\u2019m having these mice issues again."
  window_open: {fileID: -5458500939842716888, guid: dab6503fbffd2614ca2fa12a896bba97, type: 3}
