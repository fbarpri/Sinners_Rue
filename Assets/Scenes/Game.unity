  m_Script: {fileID: 11500000, guid: 788e3006a65e548f98d7c4e6d20879de, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  noPush:
  - "I regret wanting to quit drinking now. Because I hid my stash there, now I can\u2019t
    reach it. Unless I grab a chair or something to help me get up there."
  getsWine:
  - 'Goddamit. I needed a drink. '
  - "I can\u2019t believe I stuffed in so many things that they just spill out the
    moment I open the drawer."
  - "Whatever. I\u2019ll just grab one of the ones that didn\u2019t fall off."
  notAllSinsFound:
  - "These top drawers are really high up. My doctor insisted I have a \u201Cdrinking
    problem\u201D, so I hid all of my alcohol in there last night."
