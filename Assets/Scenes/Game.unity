  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 870132365}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fd900822e93a4480f924828133b83b1f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  closed_mail: {fileID: 1013523908}
  openingCloset:
  - "God. I really need to organize my closet. I probably don\u2019t even fit into
    most of these clothes anymore, I\u2019ve gained so much weight."
  - "Oh? There\u2019s something peeking out beneath my clothes."
  investigating:
  - "Ah, yes. It\u2019s some mail I got a couple of weeks ago from Jenna. I never
    got around to opening it."
  - "I haven\u2019t even seen her for years now. I wonder why she even bothers sending
    letters anymore. Sure, we used to hang out in college but now we\u2019ve drifted
    apart."
  - "Still\u2026 I\u2019m curious what the letter says. Maybe if I find some scissors
    somewhere I\u2019ll try to open it and see.  "
  gotScissors:
  - "Hah! Season\u2019s greetings. God, they even have matching pijamas. How pretentious. "
  - I hate it.
  - "I\u2019m going to burn it."
  open_closet: {fileID: 6444350374831072463, guid: 6f42822199fcd1044bae91b623a25c3d, type: 3}
  opened_mail: {fileID: 1943490335}
