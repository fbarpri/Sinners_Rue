--- !u!114 &1147281229
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1147281225}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bb49fd925082e4aedb0ee38a081c89d5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  turningOvenOn:
  - "I\u2019ll put the photo in the oven and hopefully it\u2019ll still work. The
    ink is old so I\u2019m not even sure if this will work."
  revealingText:
  - "It worked! \u2026. But,  I was\u2026 not ready to see that. It just reminds
    me of my shameful past."
  - "Ugh, this is giving me a headache. I\u2019ll pretend this never happened."
  defaultIntro:
  - "I don\u2019t really feel like baking anything right now. "
  ovenPuzzlePanel: {fileID: 789777682}
  oven_on: {fileID: 649813348802389528, guid: dab6503fbffd2614ca2fa12a896bba97, type: 3}
  oven_off: {fileID: 1817520831682859087, guid: 55a10a305b3dd8949818970d6a6fdaf4, type: 3}
  revealed_text: {fileID: 1989587784}
